# Copy to deploy/server.env before deployment and replace every CHANGE_ME value.
COMPOSE_PROJECT_NAME=railway-sim
COMPOSE_PROFILES=fmu
TARGET_PLATFORM=linux/amd64
IMAGE_TAG=local
SOURCE_COMMIT=unknown
TZ=Asia/Shanghai

INTERNAL_BIND_ADDRESS=127.0.0.1
FMU_PORT=9000
POWER_NETWORK_PORT=9200
VEHICLE_RUNTIME_PORT=9300
CENTRAL_BASE_URL=http://CHANGE_ME_CENTRAL_HOST:8080

VEHICLE_PHYSICS_MODE=FMU_HTTP
FMU_TIMEOUT_MILLIS=80
POWER_NETWORK_TIMEOUT_MILLIS=300
CENTRAL_TIMEOUT_MILLIS=300

LOG_MAX_SIZE=20m
LOG_MAX_FILES=5
